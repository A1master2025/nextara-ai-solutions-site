---
/**
 * AudienceFit.astro
 * "Who it's for" and "Not for" sections.
 * Helps prospects self-qualify.
 * Optional industry context addendum for cross-linking.
 *
 * DIOS: data-nt-section="audience-fit"
 */
interface Props {
  audienceFit: string[];
  audienceNotFit: string[];
  industryContext?: {
    text: string;
    linkText: string;
    linkHref: string;
  };
}
const { audienceFit, audienceNotFit, industryContext } = Astro.props;
---
<section class="audience-fit" data-nt-section="audience-fit">
  <div class="audience-fit__column audience-fit__column--for">
    <h2 class="audience-fit__heading">
      <span class="audience-fit__icon" aria-hidden="true">✓</span>
      Who it's for
    </h2>
    <ul class="audience-fit__list">
      {audienceFit.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>
  <div class="audience-fit__column audience-fit__column--not">
    <h2 class="audience-fit__heading">
      <span class="audience-fit__icon" aria-hidden="true">✕</span>
      Not for
    </h2>
    <ul class="audience-fit__list">
      {audienceNotFit.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>
  {industryContext && (
    <div class="audience-fit__industry">
      <p class="audience-fit__industry-text">{industryContext.text}</p>
      <a 
        href={industryContext.linkHref} 
        class="audience-fit__industry-link"
        data-nt-event="service_industry_crosslink"
      >
        {industryContext.linkText} →
      </a>
    </div>
  )}
</section>
<style>
  .audience-fit {
    display: grid;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  @media (min-width: 640px) {
    .audience-fit {
      grid-template-columns: 1fr 1fr;
    }
  }
  .audience-fit__column {
    padding: 1.5rem;
    border-radius: 0.5rem;
  }
  .audience-fit__column--for {
    background: var(--color-success-bg, #F0FDF4);
    border: 1px solid var(--color-success-border, #BBF7D0);
  }
  .audience-fit__column--not {
    background: var(--color-warning-bg, #FFFBEB);
    border: 1px solid var(--color-warning-border, #FED7AA);
  }
  .audience-fit__heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--color-brand-primary, #0B1E3A);
  }
  .audience-fit__icon {
    font-size: 1rem;
  }
  .audience-fit__column--for .audience-fit__icon {
    color: var(--color-success, #16A34A);
  }
  .audience-fit__column--not .audience-fit__icon {
    color: var(--color-warning, #D97706);
  }
  .audience-fit__list {
    margin: 0;
    padding-left: 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.6;
  }
  .audience-fit__list li {
    margin-bottom: 0.5rem;
  }
  .audience-fit__list li:last-child {
    margin-bottom: 0;
  }
  /* Industry context addendum */
  .audience-fit__industry {
    grid-column: 1 / -1;
    padding: 1.25rem 1.5rem;
    background: var(--brand-surface-muted, #F8FAFC);
    border: 1px solid var(--border-subtle, #E1E3E8);
    border-radius: 0.5rem;
  }
  .audience-fit__industry-text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--text-primary, #0F172A);
    margin: 0 0 0.75rem;
  }
  .audience-fit__industry-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--action-primary, #2563EB);
    text-decoration: none;
  }
  .audience-fit__industry-link:hover {
    text-decoration: underline;
  }
</style>